{
  "name": "clio-mcp",
  "version": "1.0.0",
  "description": "Open-source Model Context Protocol (MCP) server that connects Claude to Clio practice management. 13 tools covering matters, contacts, documents, tasks, calendar, time entries, and billing. Built for law firms with ABA Opinion 512 audit logging and AES-256 encrypted token storage.",
  "main": "build/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc && chmod 755 build/index.js",
    "start": "node build/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js"
  },
  "bin": {
    "clio-mcp": "./build/index.js"
  },
  "files": [
    "build",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oktopeak/clio-mcp.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "anthropic",
    "clio",
    "legal-tech",
    "law-firm",
    "legal-ai",
    "aba-opinion-512",
    "legal-automation",
    "practice-management",
    "oauth"
  ],
  "author": "Oktopeak <office@oktopeak.com> (https://oktopeak.com)",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/oktopeak/clio-mcp/issues"
  },
  "homepage": "https://github.com/oktopeak/clio-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.6.1",
    "open": "^11.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
